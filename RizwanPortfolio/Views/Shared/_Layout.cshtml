<body>
    @RenderBody()

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Scripts/badge.js"></script>
    @RenderSection("scripts", required: false)
